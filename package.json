{
  "name": "@mikulgohil/ai-kit",
  "version": "2.0.0",
  "description": "AI-assisted development setup kit. Auto-detects your tech stack (Next.js, Sitecore XM Cloud, Optimizely SaaS CMS, Tailwind, TypeScript, Turborepo) and generates tailored CLAUDE.md, .cursorrules, hooks, agents, context modes, slash commands, design token rules, component registries, developer guides, and spec-first workflows. Migrate existing projects, auto-backup on update, and rollback support.",
  "type": "module",
  "bin": {
    "ai-kit": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "commands",
    "guides",
    "docs-scaffolds",
    "agents",
    "contexts",
    "ai-kit.config.schema.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "claude-code",
    "cursor",
    "windsurf",
    "aider",
    "cline",
    "developer-tools",
    "cli",
    "nextjs",
    "tailwind",
    "sitecore",
    "sitecore-xm-cloud",
    "sitecore-jss",
    "optimizely",
    "optimizely-saas-cms",
    "optimizely-graph",
    "optimizely-visual-builder",
    "headless-cms",
    "docker",
    "storybook",
    "i18n",
    "hooks",
    "agents",
    "security-audit",
    "design-tokens",
    "component-registry",
    "static-site",
    "aiignore",
    "figma-to-code",
    "spec-driven",
    "project-principles",
    "extension-catalog",
    "presets",
    "constitution",
    "spec-first",
    "migrate",
    "rollback",
    "backup",
    "session-context"
  ],
  "author": {
    "name": "Mikul Gohil",
    "url": "https://www.mikul.me"
  },
  "license": "MIT",
  "homepage": "https://ai-kit.mikul.me",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikulgohil/ai-kit.git"
  },
  "bugs": {
    "url": "https://github.com/mikulgohil/ai-kit/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "fs-extra": "^11.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
